{
  "name": "ielts-platform",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "start": "node .output/server/index.mjs",
    "preview": "nuxt build && wrangler pages dev .output/public",
    "deploy": "nuxt build && wrangler pages deploy .output/public --project-name=ielts-platform",
    "seed:local-sqlite": "node --experimental-strip-types scripts/seed.ts",
    "reset-db": "node --experimental-strip-types scripts/reset-db.ts",
    "d1:schema": "wrangler d1 execute ielts-db --remote --file=./server/db/schema.sql",
    "d1:schema:local": "wrangler d1 execute ielts-db --local --file=./server/db/schema.sql",
    "d1:seed-gen": "npm run seed:local-sqlite && node --experimental-strip-types scripts/dump-d1-sql.ts",
    "d1:seed": "npm run d1:seed-gen && wrangler d1 execute ielts-db --remote --file=./data/seed.sql",
    "d1:seed:local": "npm run d1:seed-gen && wrangler d1 execute ielts-db --local --file=./data/seed.sql",
    "d1:reset": "npm run d1:schema && npm run d1:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "nuxt": "^3.13.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "better-sqlite3": "^11.3.0",
    "typescript": "^5.5.4",
    "wrangler": "^4.83.0"
  }
}
